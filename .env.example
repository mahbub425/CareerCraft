VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_project_id
VITE_APPWRITE_DATABASE_ID=your_database_id
VITE_APPWRITE_CVS_COLLECTION_ID=your_appwrite_collection_id
VITE_APPWRITE_TEMPLATES_COLLECTION_ID=your_appwrite_collection_id
VITE_APPWRITE_CATEGORIES_COLLECTION_ID=your_appwrite_collection_id
VITE_APPWRITE_DOWNLOADS_COLLECTION_ID=your_appwrite_collection_id
VITE_APPWRITE_PAYMENT_PROOFS_BUCKET_ID=your_payment_proofs_bucket_id
APPWRITE_API_KEY=your_server_api_key_for_setup_script

# Server-only AI keys. Do not prefix these with VITE_ and do not expose them in frontend code.
AI_PROVIDER=gemini
GEMINI_API_KEY=your_new_gemini_api_key
GEMINI_MODEL=gemini-flash-latest
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_SITE_NAME=Smart CV Builder

# Email for payment confirmation. Brevo works without a custom sending domain for MVP use.
EMAIL_PROVIDER=brevo
BREVO_API_KEY=your_brevo_transactional_api_key
EMAIL_FROM=CareerCraft <your_verified_sender_email@gmail.com>
ADMIN_NOTIFICATION_EMAIL=your_admin_email@gmail.com
APP_URL=http://localhost:5173

# Optional Brevo SMTP mode. Use EMAIL_PROVIDER=brevo-smtp if you prefer SMTP credentials.
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_brevo_smtp_login
BREVO_SMTP_PASS=your_brevo_smtp_key

# Optional Resend email provider. Use a verified Resend domain.
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=CareerCraft <noreply@yourdomain.com>
